---
import Base from '../layouts/Base.astro';
import servicesData from '../content/pages/services.json';

const { seo_description, intro, pre_production, recording, mixing, session_musicians } = servicesData;
---

<Base title="Services & Gear | Lost Unfound Records" description={seo_description}>
  <div class="page-section">
    <p class="text-label">What we offer</p>
    <h1 class="text-display" data-scramble>
      <span data-word="What">What</span>
      <span data-word="We Do">We Do</span>
    </h1>

    <p class="intro">{intro}</p>

    <section class="content-section">
      <div class="service-list">
        <div class="service-item">
          <h3>Pre-Production</h3>
          <p>{pre_production}</p>
        </div>

        <div class="service-item">
          <h3>Recording & Production</h3>
          <p>{recording}</p>
        </div>

        <div class="service-item">
          <h3>Mixing</h3>
          <p>{mixing}</p>
        </div>

        <div class="service-item">
          <h3>Session Musicians</h3>
          <p>{session_musicians}</p>
        </div>
      </div>
    </section>

    <section class="content-section">
      <h2 class="text-heading">Equipment</h2>

      <div class="gear-grid">
        <div class="gear-category">
          <h3 class="text-label">Microphones</h3>
          <ul>
            <li class="gear-subheading">Condenser</li>
            <li>Lauten Audio Clarion FC-357</li>
            <li>Rode NT1-A</li>
            <li>Studio Projects C1</li>
            <li>Blue Baby Bottle SL</li>
            <li>SE Kick V</li>
            <li>Shure PG98a (×2)</li>
            <li class="gear-subheading">Dynamic</li>
            <li>Shure SM57 (×2)</li>
            <li>Shure SM58</li>
            <li>Shure Beta 52A</li>
            <li class="gear-subheading">Ribbon</li>
            <li>T-Bone RB500 (×2)</li>
            <li>Superlux R102</li>
          </ul>
        </div>

        <div class="gear-category">
          <h3 class="text-label">Production & Monitoring</h3>
          <ul>
            <li class="gear-subheading">Audio Interfaces</li>
            <li>Audient EVO 16</li>
            <li>Behringer ADA8200</li>
            <li>Motu M4</li>
            <li>M-Audio M-Track 2×2</li>
            <li class="gear-subheading">Headphones</li>
            <li>Beyerdynamic DT990 Pro 250Ω (×2)</li>
            <li>Sony MDR-7506</li>
            <li>Zoom ZHP-1</li>
            <li class="gear-subheading">Additional</li>
            <li>HK Powerworks Sound House PA (2 heads + sub)</li>
            <li>Yamaha MG12XU Mixer</li>
          </ul>
        </div>

        <div class="gear-category">
          <h3 class="text-label">Instruments</h3>
          <ul>
            <li class="gear-subheading">Keys & Synths</li>
            <li>Yamaha C3 Baby Grand</li>
            <li>Korg SV1</li>
            <li>Korg Kronos</li>
            <li>Roland V-Combo V9</li>
            <li>ASM Hydrasynth Deluxe</li>
            <li>Behringer UB-XA</li>
            <li>Behringer DeepMind 6</li>
            <li class="gear-subheading">Strings</li>
            <li>D'Angelico Acoustic Guitar</li>
            <li>Ovation 12-String Acoustic</li>
            <li>Eko Relic Electric Guitar</li>
            <li>Eko Electric Bass</li>
            <li class="gear-subheading">Drums</li>
            <li>Pearl World Series (1984)</li>
            <li>Vintage Pearl World Series 6.5×15"</li>
            <li>14"×5" Pearl Wooden Snare</li>
          </ul>
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  h1 {
    margin-block: 1rem 0;
  }

  .intro {
    max-width: min(70ch, 100%);
    color: var(--color-muted);
    font-size: 1.1rem;
    margin-top: 2rem;
  }

  .content-section {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  h2 {
    margin-top: 0;
    margin-bottom: 2rem;
  }

  .service-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem 3rem;
  }

  .service-item h3 {
    font-family: "Syne", sans-serif;
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
  }

  .service-item p {
    color: var(--color-muted);
    max-width: min(55ch, 100%);
  }

  .gear-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .gear-category h3 {
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .gear-category ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .gear-category li {
    color: var(--color-muted);
    font-size: 0.875rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .gear-subheading {
    color: var(--color-text);
    font-size: 0.7rem !important;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding-top: 1rem !important;
    border-bottom: none !important;
  }

  .gear-subheading:first-child {
    padding-top: 0 !important;
  }

  @media (max-width: 900px) {
    .service-list,
    .gear-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
