---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
import FilterBar from '../components/FilterBar.astro';
import ProjectGrid from '../components/ProjectGrid.astro';

const projects = (await getCollection('projects'))
  .filter((project) => project.data.published !== false)
  .sort((a, b) => b.data.publish_date.getTime() - a.data.publish_date.getTime());
---

<Base title="Lost Unfound Records">
  <section class="page-section hero">
    <p class="text-label">Forli / Bologna — Italy</p>
    <h1 class="text-hero" id="hero-title" data-final="Lost Unfound">Lost Unfound</h1>
    <p class="intro">
      Independent production and recording studio focused on texture, songwriting, and emotionally honest records.
    </p>
    <Button href="/contact" label="Start a Project" />
  </section>

  <section class="page-section">
    <h2 class="text-heading">Portfolio</h2>
    <FilterBar />
    <ProjectGrid projects={projects} />
  </section>
</Base>

<script>
  const target = document.getElementById('hero-title');
  if (target) {
    const finalText = target.dataset.final || target.textContent || '';
    const chars = '!<>-_\\/[]{}=+*^?#________';
    let frame = 0;
    const totalFrames = 20;

    const scramble = () => {
      const progress = frame / totalFrames;
      const revealCount = Math.floor(finalText.length * progress);
      target.textContent = finalText
        .split('')
        .map((char, i) => (i < revealCount ? char : chars[Math.floor(Math.random() * chars.length)]))
        .join('');

      frame += 1;
      if (frame <= totalFrames) {
        setTimeout(scramble, 40);
      } else {
        target.textContent = finalText;
      }
    };

    setTimeout(scramble, 120);
  }
</script>

<style>
  .hero {
    min-height: 62vh;
    display: grid;
    align-content: end;
    gap: 1.25rem;
  }

  .intro {
    max-width: 62ch;
    color: var(--color-muted);
  }

  h2 {
    margin-top: 0;
    margin-bottom: 1.5rem;
  }
</style>
