---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
import FilterBar from '../components/FilterBar.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import homeData from '../content/pages/home.json';

const { intro, seo_description } = homeData;

const projects = (await getCollection('projects'))
  .filter((project) => project.data.published !== false)
  .sort((a, b) => b.data.publish_date.getTime() - a.data.publish_date.getTime());
---

<Base title="Lost Unfound Records" description={seo_description}>
  <section class="page-section hero">
    <p class="text-label">Forli / Bologna — Italy</p>
    <h1 class="text-hero" id="hero-title" data-scramble>
      <span data-word="Lost">Lost</span>
      <span data-word="Unfound">Unfound</span>
    </h1>
    <p class="intro">{intro}</p>
    <div class="cta-wrap">
      <Button href="/contact" label="Start a Project" />
      <a href="#portfolio" class="scroll-cta text-label">
        See what we've worked on
        <span class="scroll-arrow" aria-hidden="true">↓</span>
      </a>
    </div>
  </section>

  <section class="page-section" id="portfolio">
    <h2 class="text-heading">Portfolio</h2>
    <FilterBar />
    <ProjectGrid projects={projects} />
  </section>
</Base>


<style>
  .hero {
    /* Fills the visible screen so the portfolio starts just below the fold.
       Content stays in the lower-middle area via padding-bottom. */
    min-height: calc(100svh - 4.5rem);
    display: grid;
    align-content: end;
    gap: 1.25rem;
    padding-bottom: clamp(4rem, 38svh, 20rem);
  }

  .intro {
    color: var(--color-muted);
  }

  .text-hero {
    display: grid;
    gap: 0.05em;
    margin: 0;
    margin-left: -0.04em;
  }

  .text-hero span {
    display: block;
  }

  .cta-wrap {
    max-width: min(62ch, 100%);
    margin-top: 1.5rem;
    opacity: 0;
    transform: translateY(10px);
    animation: cta-enter 0.5s ease-out forwards;
    animation-delay: 1s;
  }

  .cta-wrap :global(.btn) {
    width: 100%;
    justify-content: center;
  }

  .scroll-cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    width: fit-content;
  }

  .scroll-cta:hover {
    color: var(--color-text);
  }

  .scroll-arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .scroll-cta:hover .scroll-arrow {
    transform: translateY(3px);
  }

  h2 {
    margin-top: 0;
    margin-bottom: 1.5rem;
  }

  @keyframes cta-enter {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
