---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
import FilterBar from '../components/FilterBar.astro';
import ProjectGrid from '../components/ProjectGrid.astro';

const projects = (await getCollection('projects'))
  .filter((project) => project.data.published !== false)
  .sort((a, b) => b.data.publish_date.getTime() - a.data.publish_date.getTime());
---

<Base title="Lost Unfound Records">
  <section class="page-section hero">
    <p class="text-label">Forli / Bologna — Italy</p>
    <h1 class="text-hero" id="hero-title">
      <span data-word="Lost">Lost</span>
      <span data-word="Unfound">Unfound</span>
    </h1>
    <p class="intro">
      Independent production and recording studio focused on texture, songwriting, and emotionally honest records.
    </p>
    <div class="cta-wrap">
      <Button href="/contact" label="Start a Project" />
    </div>
  </section>

  <section class="page-section">
    <h2 class="text-heading">Portfolio</h2>
    <FilterBar />
    <ProjectGrid projects={projects} />
  </section>
</Base>

<script>
  const chars = '!<>-_\\/[]{}=+*^?#________';

  function scrambleLine(el: HTMLElement, delay: number) {
    const final = el.dataset.word || el.textContent || '';
    let frame = 0;
    const totalFrames = 18;

    const tick = () => {
      const progress = frame / totalFrames;
      const revealed = Math.floor(final.length * progress);
      el.textContent = final
        .split('')
        .map((ch, i) =>
          i < revealed ? ch : chars[Math.floor(Math.random() * chars.length)]
        )
        .join('');
      frame++;
      if (frame <= totalFrames) {
        setTimeout(tick, 40);
      } else {
        el.textContent = final;
      }
    };

    setTimeout(tick, delay);
  }

  const spans = document.querySelectorAll<HTMLElement>('#hero-title span[data-word]');
  spans.forEach((el, i) => scrambleLine(el, 120 + i * 200));

  // Match button width to the rendered width of the intro paragraph
  const intro = document.querySelector<HTMLElement>('.intro');
  const ctaWrap = document.querySelector<HTMLElement>('.cta-wrap');
  if (intro && ctaWrap) {
    const setWidth = () => {
      ctaWrap.style.width = `${intro.getBoundingClientRect().width}px`;
    };
    setWidth();
    window.addEventListener('resize', setWidth);
  }
</script>

<style>
  .hero {
    min-height: 62vh;
    display: grid;
    align-content: end;
    gap: 1.25rem;
  }

  .intro {
    max-width: 62ch;
    color: var(--color-muted);
  }

  .text-hero {
    display: grid;
    gap: 0.05em;
    margin: 0;
  }

  .text-hero span {
    display: block;
  }

  .cta-wrap {
    opacity: 0;
    transform: translateY(10px);
    animation: cta-enter 0.5s ease-out forwards;
    animation-delay: 1s;
  }

  .cta-wrap :global(.btn) {
    width: 100%;
    justify-content: center;
  }

  h2 {
    margin-top: 0;
    margin-bottom: 1.5rem;
  }

  @keyframes cta-enter {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
