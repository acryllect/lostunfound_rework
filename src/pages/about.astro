---
import Base from '../layouts/Base.astro';
import aboutData from '../content/pages/about.json';

const {
  intro,
  alessandro_name, alessandro_role, alessandro_bio,
  davide_name, davide_role, davide_bio,
} = aboutData;
---

<Base title="About | Lost Unfound Records">
  <div class="page-section">
    <p class="text-label">Who we are</p>
    <h1 class="text-display" data-scramble>
      <span data-word="Built Around">Built Around</span>
      <span data-word="the Song">the Song</span>
    </h1>

    {(intro as string[]).map((p: string) => <p class="intro">{p}</p>)}

    <div class="profiles">
      <article class="profile">
        <div class="profile-img-wrap">
          <img
            src="https://images.unsplash.com/photo-1519681393784-d120267933ba?w=600&q=80"
            alt="Alessandro Pelosio"
          />
        </div>
        <div class="profile-text">
          <h2 class="text-heading">{alessandro_name}</h2>
          <p class="text-label role">{alessandro_role}</p>
          {(alessandro_bio as string[]).map((p: string) => <p>{p}</p>)}
        </div>
      </article>

      <article class="profile reverse">
        <div class="profile-img-wrap">
          <img
            src="https://images.unsplash.com/photo-1470225620780-dba8ba36b745?w=600&q=80"
            alt="Davide Bacchi"
          />
        </div>
        <div class="profile-text">
          <h2 class="text-heading">{davide_name}</h2>
          <p class="text-label role">{davide_role}</p>
          {(davide_bio as string[]).map((p: string) => <p>{p}</p>)}
        </div>
      </article>
    </div>
  </div>
</Base>

<style>
  .intro {
    max-width: min(70ch, 100%);
    color: var(--color-muted);
    margin: 0;
    font-size: 1.1rem;
  }

  h1 + .intro {
    margin-top: 2rem;
  }

  .intro + .intro {
    margin-top: 1rem;
    margin-bottom: 4rem;
  }

  h1 {
    margin-block: 1rem 0;
  }

  .profiles {
    display: grid;
    gap: 6rem;
  }

  .profile {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 3rem;
    align-items: start;
  }

  .profile.reverse {
    grid-template-columns: 1.4fr 1fr;
  }

  .profile.reverse .profile-img-wrap {
    order: 2;
  }

  .profile.reverse .profile-text {
    order: 1;
  }

  .profile-img-wrap {
    border: 1px solid var(--color-border);
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .profile-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(30%);
  }

  .profile-text .role {
    color: var(--color-accent);
    margin-block: 0.5rem 1.25rem;
  }

  .profile-text p {
    color: var(--color-muted);
    max-width: min(60ch, 100%);
  }

  .profile-text p + p {
    margin-top: 1rem;
  }

  @media (max-width: 760px) {
    .profiles {
      gap: 3.5rem;
    }

    .profile,
    .profile.reverse {
      grid-template-columns: 1fr;
    }

    .profile.reverse .profile-img-wrap {
      order: 0;
    }

    .profile.reverse .profile-text {
      order: 1;
    }

    .profile-img-wrap {
      aspect-ratio: 4 / 3;
    }
  }
</style>
