---
import Base from '../layouts/Base.astro';
import contactData from '../content/pages/contact.json';

const { seo_description, lead, no_form_note, email, location, response_time, availability } = contactData;
---

<Base title="Contact | Lost Unfound Records" description={seo_description}>
  <div class="page-section contact-wrap">
    <p class="text-label">Get in touch</p>
    <h1 class="text-display" data-scramble>
      <span data-word="Start">Start</span>
      <span data-word="here.">here.</span>
    </h1>

    <p class="lead">{lead}</p>
    <p class="lead no-form">{no_form_note}</p>

    <div class="contact-block">
      <p class="text-label block-label">Email</p>
      <a class="email-link text-heading" href={`mailto:${email}`}>{email}</a>
    </div>

    <div class="detail-list">
      <div class="detail-item">
        <p class="text-label">Location</p>
        <p>{location}</p>
      </div>
      <div class="detail-item">
        <p class="text-label">Response time</p>
        <p>{response_time}</p>
      </div>
      <div class="detail-item">
        <p class="text-label">Availability</p>
        <p>{availability}</p>
      </div>
    </div>
  </div>
</Base>

<style>
  h1 {
    margin-block: 1rem 2rem;
  }

  .lead {
    color: var(--color-muted);
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .no-form {
    margin-bottom: 3rem;
  }

  .contact-block {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .block-label {
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .email-link {
    text-decoration: none;
    display: inline-block;
    transition: color 0.2s ease;
    word-break: break-all;
  }

  .email-link:hover {
    color: var(--color-accent);
  }

  .detail-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .detail-item .text-label {
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .detail-item p:last-child {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  @media (max-width: 680px) {
    .detail-list {
      grid-template-columns: 1fr;
    }

    .email-link {
      font-size: clamp(1.1rem, 5vw, 1.5rem);
    }
  }
</style>
