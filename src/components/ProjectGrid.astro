---
import ProjectCard from './ProjectCard.astro';
const { projects } = Astro.props;
---

<section class="project-grid" id="project-grid">
  {projects.map((project, index) => <ProjectCard project={project} featured={index === 0} />)}
</section>

<script>
  const grid = document.getElementById('project-grid');
  if (grid) {
    const cards = [...grid.querySelectorAll('.project-card')];
    window.addEventListener('project-filter-change', (event) => {
      const selected: string[] = event.detail;
      cards.forEach((card) => {
        const cardCats: string[] = JSON.parse(card.dataset.categories || '[]');
        // AND logic: show only if card has every selected category
        const match = selected.length === 0 || selected.every((s) => cardCats.includes(s));
        card.style.transition = 'opacity 150ms ease';
        card.style.opacity = match ? '1' : '0';
        setTimeout(() => {
          card.style.display = match ? '' : 'none';
          if (match) card.style.opacity = '1';
        }, 150);
      });
    });
  }
</script>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .project-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
