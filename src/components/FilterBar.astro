---
const categories = ['Songwriting', 'Production', 'Mixing', 'Mastering'];
---

<div class="filter-bar" id="filter-bar">
  <button class="filter-button text-label is-active" data-filter="All" type="button">
    All
  </button>
  {categories.map((category) => (
    <button class="filter-button text-label" data-filter={category} type="button">
      {category}
    </button>
  ))}
</div>

<script>
  const bar = document.getElementById('filter-bar');
  if (bar) {
    const allBtn = bar.querySelector<HTMLButtonElement>('[data-filter="All"]')!;
    const catBtns = [...bar.querySelectorAll<HTMLButtonElement>('.filter-button:not([data-filter="All"])')];
    const selected = new Set<string>();

    function updateAll() {
      const noneActive = selected.size === 0;
      allBtn.classList.toggle('is-active', noneActive);
      catBtns.forEach((b) => b.classList.toggle('is-active', selected.has(b.dataset.filter!)));
      window.dispatchEvent(new CustomEvent('project-filter-change', { detail: [...selected] }));
    }

    allBtn.addEventListener('click', () => {
      selected.clear();
      updateAll();
    });

    catBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const val = btn.dataset.filter!;
        if (selected.has(val)) {
          selected.delete(val);
        } else {
          selected.add(val);
        }
        updateAll();
      });
    });
  }
</script>

<style>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .filter-button {
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text);
    padding: 0.5rem 0.8rem;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .filter-button:hover,
  .filter-button.is-active {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 18%, transparent);
  }
</style>
