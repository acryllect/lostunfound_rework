---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/contact', label: 'Contact' },
  { href: '/disclaimer', label: 'Disclaimer' },
];
---

<header class="site-nav">
  <div class="container nav-inner">
    <a class="logo text-label" href="/">Lost Unfound</a>
    <button class="menu-toggle text-label" type="button" aria-expanded="false" aria-controls="main-menu">
      Menu
    </button>
    <nav id="main-menu" class="menu">
      <ul>
        {links.map((link) => (
          <li>
            <a href={link.href} class="menu-link text-label">
              {link.label}
              <span class="menu-line"></span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const menu = document.querySelector('.menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      menu.classList.toggle('open');
    });
  }
</script>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--color-bg) 90%, transparent);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--color-border);
    animation: nav-enter 0.6s ease-out both;
    animation-delay: 0.2s;
  }

  @keyframes nav-enter {
    from {
      transform: translateY(-100%);
    }
    to {
      transform: translateY(0);
    }
  }

  .nav-inner {
    min-height: 4.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    text-decoration: none;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 0.5rem 0.75rem;
  }

  .menu ul {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .menu-link {
    position: relative;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    height: 4.5rem;
    padding-bottom: 0;
    overflow: hidden;
  }

  .menu-line {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 250ms ease;
  }

  .menu-link:hover .menu-line {
    transform: scaleX(1);
  }

  @media (max-width: 760px) {
    .menu-toggle {
      display: block;
    }

    .menu {
      display: none;
      width: 100%;
      position: absolute;
      top: 100%;
      left: 0;
      background: var(--color-surface);
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      padding: 1rem clamp(1.5rem, 4vw, 5rem);
    }

    .menu.open {
      display: block;
    }

    .menu ul {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
