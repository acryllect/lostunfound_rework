---
const { project, featured = false } = Astro.props;
const data = project.data;
---

<article class:list={['project-card', featured && 'featured']} data-category={data.category}>
  <a href={`/projects/${project.id}`} class="card-link">
    <img src={data.cover_image} alt={`${data.title} cover art`} loading="lazy" />
    <div class="overlay">
      <span class="text-label category">{data.category}</span>
      <h3>{data.title}</h3>
      <p>{data.artist}</p>
    </div>
  </a>
</article>

<style>
  .project-card {
    position: relative;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    min-height: 240px;
  }

  .featured {
    grid-column: span 2;
    min-height: 520px;
  }

  .card-link {
    display: block;
    position: relative;
    height: 100%;
    text-decoration: none;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.5rem;
    padding: 1rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .project-card:hover .overlay {
    opacity: 1;
    transform: translateY(0);
  }

  .category {
    color: var(--color-accent);
  }

  h3 {
    margin: 0;
    font-family: "Syne", sans-serif;
    font-size: 1.5rem;
    line-height: 1;
  }

  p {
    margin: 0;
  }

  @media (max-width: 1024px) {
    .featured {
      grid-column: span 1;
      min-height: 320px;
    }

    .overlay {
      opacity: 1;
      transform: none;
    }
  }
</style>
