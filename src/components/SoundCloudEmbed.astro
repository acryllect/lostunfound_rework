---
const { url } = Astro.props;
const embedUrl = url
  ? `https://w.soundcloud.com/player/?url=${encodeURIComponent(url)}&color=%23c8301a&auto_play=false`
  : '';
---

{
  embedUrl ? (
    <iframe
      width="100%"
      height="166"
      scrolling="no"
      frameborder="no"
      allow="autoplay"
      src={embedUrl}
      title="SoundCloud embed"
      loading="lazy"
    ></iframe>
  ) : null
}
