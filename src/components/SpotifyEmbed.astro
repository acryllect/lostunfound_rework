---
const { url } = Astro.props;
const embedUrl = url ? url.replace('open.spotify.com/', 'open.spotify.com/embed/') : '';
---

{embedUrl && (
  <div
    class="spotify-facade"
    data-embed-url={embedUrl}
    role="button"
    tabindex="0"
    aria-label="Load Spotify player"
  >
    <div class="facade-inner">
      <svg class="spotify-logo" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
      </svg>
      <span class="facade-label">Load Spotify Player</span>
      <svg class="play-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M8 5v14l11-7z"/>
      </svg>
    </div>
  </div>
)}

<script>
  function activateFacade(facade: HTMLElement) {
    const embedUrl = facade.dataset.embedUrl;
    if (!embedUrl) return;
    const iframe = document.createElement('iframe');
    iframe.src = embedUrl;
    iframe.title = 'Spotify player';
    iframe.width = '100%';
    iframe.height = '152';
    iframe.setAttribute('frameborder', '0');
    iframe.allow = 'autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture';
    iframe.style.display = 'block';
    iframe.style.borderRadius = '12px';
    facade.replaceWith(iframe);
  }

  document.querySelectorAll<HTMLElement>('.spotify-facade').forEach((facade) => {
    facade.addEventListener('click', () => activateFacade(facade));
    facade.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') activateFacade(facade);
    });
  });
</script>

<style>
  .spotify-facade {
    width: 100%;
    height: 152px;
    background: #181818;
    border-radius: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #282828;
    transition: background 0.2s ease;
    user-select: none;
  }

  .spotify-facade:hover {
    background: #242424;
  }

  .facade-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #b3b3b3;
    transition: color 0.2s ease;
  }

  .spotify-facade:hover .facade-inner {
    color: #fff;
  }

  .spotify-logo {
    width: 22px;
    height: 22px;
    color: #1db954;
    flex-shrink: 0;
  }

  .facade-label {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .play-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
</style>
